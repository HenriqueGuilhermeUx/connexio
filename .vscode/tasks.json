{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Connexio: abrir no navegador",
      "type": "npm",
      "script": "web",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": false }
    },
    {
      "label": "Connexio: iniciar no celular (Expo Go)",
      "type": "npm",
      "script": "start:tunnel",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Connexio: validar projeto",
      "type": "shell",
      "command": "npm run typecheck && npm run lint",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": false }
    },
    {
      "label": "Expo: entrar na conta",
      "type": "shell",
      "command": "npx eas-cli@latest login",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Expo: vincular projeto Connexio",
      "type": "shell",
      "command": "npx eas-cli@latest init",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Expo: publicar piloto web",
      "type": "shell",
      "command": "npx expo export --platform web && npx eas-cli@latest deploy",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Expo: gerar APK de teste",
      "type": "shell",
      "command": "npx eas-cli@latest build --platform android --profile preview",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Expo: gerar Android para Play Store",
      "type": "shell",
      "command": "npx eas-cli@latest build --platform android --profile production",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Expo: enviar Android para Play Store",
      "type": "shell",
      "command": "npx eas-cli@latest submit --platform android --profile production",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    }
  ]
}
