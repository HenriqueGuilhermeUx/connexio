{
  "expo": {
    "name": "Connexio",
    "slug": "connexio",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "connexio",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.alternativeventures.connexio"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "br.com.alternativeventures.connexio"
    },
    "web": {
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
